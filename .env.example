# App
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muda_juara?schema=public"
IRON_SESSION_PASSWORD="ganti-dengan-random-secret-minimal-32-karakter"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Optional: used by docker-compose.easypanel.yml
DB_PASSWORD="postgres"

# Optional: WhatsApp API for OTP
WAHA_URL="http://localhost:3001"

# Optional: Base URL for QR check-in (default: http://localhost:3000)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Optional: Custom seed password (random if not set)
ADMIN_SEED_PASSWORD="your-custom-admin-password"
